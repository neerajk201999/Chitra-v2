{
  "name": "chitra-video",
  "version": "0.6.0-rc.2",
  "description": "Deterministic Chitra core: multimodal intake, transcript editing and evidence, Motion IR, rendering, gates, and critic evidence",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc",
    "prepack": "tsc && node ../scripts/prepare-package.mjs"
  },
  "keywords": [
    "video",
    "motion-design",
    "ai",
    "agent",
    "rendering",
    "ffmpeg",
    "quality",
    "cinematic"
  ],
  "author": "Neeraj Kanoi",
  "license": "MIT",
  "type": "module",
  "bin": {
    "chitra": "dist/cli/index.js"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "gsap": "^3.15.0",
    "puppeteer-core": "^25.3.0",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neerajk201999/Chitra-v2.git"
  },
  "homepage": "https://github.com/neerajk201999/Chitra-v2#readme",
  "bugs": {
    "url": "https://github.com/neerajk201999/Chitra-v2/issues"
  },
  "engines": {
    "node": ">=22.12"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "runtime-assets",
    "styles",
    "README.md",
    "LICENSE"
  ]
}
